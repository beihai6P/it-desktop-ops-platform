# 服务配置
PORT=5000
NODE_ENV=production

# 数据库配置
MONGODB_URI=mongodb://127.0.0.1:27017/itops-platform

# JWT配置
JWT_SECRET=your-secret-key-here-must-be-at-least-32-characters
JWT_EXPIRES_IN=7d

# 存储配置
# 可选值: local | volcengine
STORAGE_TYPE=local
STORAGE_ROOT=./storage

# 火山引擎对象存储配置（仅当 STORAGE_TYPE=volcengine 时需要配置）
VOLC_ACCESS_KEY_ID=
VOLC_SECRET_ACCESS_KEY=
VOLC_REGION=cn-shanghai
VOLC_ENDPOINT=tos-cn-shanghai.volces.com
VOLC_BUCKET=
VOLC_ACCOUNT_ID=

# CORS配置
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,https://your-domain.com

# API配置
API_BASE_URL=http://localhost:5000